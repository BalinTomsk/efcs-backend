# Copy to `.env` for local development (gitignored). In production, inject these as real environment
# variables — they always take precedence over the .env file.

# Shared JDBC-style URL (same shape as the other FishFind backend services). A native SqlClient
# connection string (e.g. "Server=host,1433;Database=db;Encrypt=True;TrustServerCertificate=True")
# is also accepted.
DB_URL=jdbc:sqlserver://host.docker.internal:1433;databaseName=your_database;encrypt=true;trustServerCertificate=true
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Optional: point the loader at a .env file elsewhere (defaults to ./.env).
# DOTENV_PATH=/app/.env

# Optional worker overrides (double underscore = configuration section nesting):
# Water__Worker__Enabled=true
# Water__Worker__Cron=0 0 * * * *
# Water__Worker__PauseBetweenStationsMs=1000
# Water__Worker__ConnectTimeoutMs=15000
# Water__Worker__ReadTimeoutMs=30000
